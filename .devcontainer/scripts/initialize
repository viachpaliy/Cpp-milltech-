#!/usr/bin/env bash
set -euo pipefail

# Runs on the host (macOS, Linux, WSL2) before the container starts.
# Creates a bash history file under the host's home so shell history
# persists across container rebuilds.
DEVCONTAINER_DATA_ON_HOST="${HOME}/.devcontainers/$(basename "${PWD}")"
mkdir -p "${DEVCONTAINER_DATA_ON_HOST}"
touch "${DEVCONTAINER_DATA_ON_HOST}/.bash_history"

# Ensure ~/.ssh exists so the bind-mount in devcontainer.json does not fail
# on fresh machines where the user never generated SSH keys yet.
[ -d "${HOME}/.ssh" ] || mkdir -m 700 "${HOME}/.ssh"
